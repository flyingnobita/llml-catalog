---
// browse.astro — filterable catalog browse page with loading/error states.
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Badge from "../components/Badge.astro";
import { PROFILES, FILTERS } from "../data/profiles";

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Browse Profiles"
  description="Filter by backend, hardware class, OS, and use case. Every profile is a portable TOML file from a public GitHub repo."
>
  <section style="border-bottom:1px solid var(--border);padding:32px">
    <div style="max-width:1280px;margin:0 auto;display:flex;flex-direction:column;gap:12px">
      <span class="eyebrow">browse</span>
      <h1 style="font-size:40px;letter-spacing:-0.01em">Profiles for local LLMs</h1>
      <p style="color:var(--muted);font-size:15px">
        Filter by backend, hardware class, OS, and use case. Every profile is a portable TOML file
        from a public GitHub repo.
      </p>
    </div>
  </section>

  <!-- Mobile search + filter toggle (visible ≤700px) -->
  <div id="filter-toggle-bar" class="mobile-only" style="max-width:1280px;margin:0 auto;padding:16px 16px 12px;flex-direction:row;gap:8px;align-items:stretch">
    <input
      id="search-mobile"
      type="text"
      placeholder="Search profiles…"
      style="font:inherit;color:var(--ink);height:40px;padding:0 12px;border:1px solid var(--border);border-radius:4px;background:var(--surface-raised);flex:1 1 auto;min-width:0;box-sizing:border-box"
    />
    <button id="filter-toggle" aria-label="Filters" aria-expanded="false" aria-controls="filters" style="font:inherit;padding:0;border:1px solid var(--border);border-radius:4px;background:var(--surface-raised);color:var(--ink);cursor:pointer;display:inline-flex;align-items:center;justify-content:center;width:40px;height:40px;flex:0 0 40px;position:relative">
      <svg width="16" height="16" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="2" y1="3" x2="12" y2="3"/><line x1="4" y1="7" x2="10" y2="7"/><line x1="6" y1="11" x2="8" y2="11"/></svg>
      <span id="filter-count-badge" hidden style="position:absolute;top:-4px;right:-4px;background:var(--primary);color:#fff;border-radius:999px;font-family:var(--font-mono);font-size:10px;min-width:16px;height:16px;align-items:center;justify-content:center;padding:0 4px;border:1.5px solid var(--paper);box-sizing:border-box">0</span>
    </button>
  </div>

  <div style="max-width:1280px;margin:0 auto;padding:24px 32px;display:grid;grid-template-columns:220px 1fr;gap:32px">
    <!-- Filter sidebar -->
    <aside id="filters" style="display:flex;flex-direction:column;gap:24px">
      <!-- Mobile drawer header (hidden on desktop) -->
      <div id="filter-drawer-header" class="mobile-only" style="display:flex;align-items:center;justify-content:space-between">
        <span class="eyebrow">Filters</span>
        <button id="filter-close" aria-label="Close filters" style="font:inherit;background:transparent;border:0;cursor:pointer;font-size:22px;color:var(--muted);padding:4px 8px;line-height:1">×</button>
      </div>

      <div style="position:relative">
        <input
          id="search"
          type="text"
          placeholder="Search profiles…"
          style="font:inherit;color:var(--ink);padding:8px 12px;padding-right:36px;border:1px solid var(--border);border-radius:8px;background:var(--surface-raised);width:100%;box-sizing:border-box"
        />
        <kbd class="search-shortcut" style="position:absolute;right:8px;top:50%;transform:translateY(-50%);font-family:var(--font-mono);font-size:11px;padding:2px 6px;border:1px solid var(--border);border-bottom-width:2px;border-radius:4px;background:var(--paper);color:var(--muted);pointer-events:none">/</kbd>
      </div>
      {[
        { key: "backend", title: "Backend", options: FILTERS.backend },
        { key: "hardware", title: "Hardware class", options: FILTERS.hardware },
        { key: "os", title: "Operating system", options: FILTERS.os },
        { key: "useCase", title: "Use case", options: FILTERS.useCase },
        { key: "tags", title: "Capabilities", options: FILTERS.tags },
        { key: "modelOrg", title: "Model org", options: FILTERS.modelOrg },
        { key: "profileOrg", title: "Profile org", options: FILTERS.profileOrg },
        { key: "source", title: "Source", options: FILTERS.source },
      ].map((g) => (
        <div class="filter-group" data-key={g.key} style="display:flex;flex-direction:column;gap:6px">
          <span class="eyebrow">{g.title}</span>
          <div style="display:flex;flex-direction:column;gap:2px">
            {g.options.map((o: string) => (
              <button class="filter-opt" data-group={g.key} data-value={o} style="font:inherit;text-align:left;background:transparent;border:0;padding:4px 0;cursor:pointer;font-family:var(--font-sans);font-size:13px;color:var(--muted);font-weight:400;display:flex;gap:8px;align-items:center">
                <span class="filter-dot" style="width:12px;height:12px;border-radius:2px;border:1px solid var(--border);background:transparent;display:inline-block;flex-shrink:0"></span>
                {o}
              </button>
            ))}
          </div>
        </div>
      ))}
      <!-- Mobile drawer footer (hidden on desktop) -->
      <div id="filter-drawer-footer" class="mobile-only" style="display:flex;gap:8px;position:sticky;bottom:0;background:var(--paper);padding-top:12px;border-top:1px solid var(--border);margin-top:auto">
        <button id="filter-clear-all" style="font:inherit;font-family:var(--font-sans);font-size:13px;padding:10px 16px;border:1px solid var(--border);border-radius:var(--r-md);background:transparent;color:var(--muted);cursor:pointer;flex:1">Clear all</button>
        <button id="filter-apply" style="font:inherit;font-family:var(--font-sans);font-size:13px;font-weight:600;padding:10px 24px;border:0;border-radius:var(--r-md);background:var(--ink);color:var(--paper);cursor:pointer;flex:1">Apply</button>
      </div>
    </aside>

    <!-- Result list -->
    <main>
      <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:12px;border-bottom:1px solid var(--ink)">
        <span id="count" style="font-family:var(--font-mono);font-size:13px">
          <strong>{PROFILES.length}</strong> <span style="color:var(--muted)">of {PROFILES.length} profiles</span>
        </span>
        <div style="display:none;gap:8px;align-items:center">
          <span class="eyebrow">sort</span>
          <select id="sort" style="font:inherit;color:var(--ink);padding:6px 10px;border:1px solid var(--border);border-radius:8px;background:var(--surface-raised)">
            <option>Updated</option>
            <option>Fit</option>
            <option>Name</option>
          </select>
        </div>
      </div>

      <!-- Column headers -->
      <div style="display:grid;grid-template-columns:20px 1fr 120px 130px 100px 100px 110px;gap:16px;padding:10px 0;border-bottom:1px solid var(--border);font-family:var(--font-mono);font-size:11px;color:var(--muted);letter-spacing:.08em;text-transform:uppercase">
        <span></span><span>Profile</span><span>Backend</span><span>Hardware</span><span>OS</span><span>Updated</span><span></span>
      </div>

      <!-- Result rows -->
      <div id="results">
        <!-- Skeleton loading rows (shown during fetch) -->
        {[0, 1, 2, 3].map((i) => (
          <div class="skeleton-row" style="border-bottom:1px solid var(--border);padding:14px 0;display:grid;grid-template-columns:20px 1fr 120px 130px 100px 100px 110px;gap:16px;align-items:center">
            <div style="width:16px;height:16px;border-radius:2px;background:var(--paper-2)"></div>
            <div>
              <div style="width:55%;height:14px;background:var(--paper-2);border-radius:4px"></div>
              <div style="width:78%;height:12px;background:var(--paper-2);border-radius:4px;margin-top:8px"></div>
            </div>
            <div style="width:70px;height:12px;background:var(--paper-2);border-radius:4px"></div>
            <div style="width:90px;height:12px;background:var(--paper-2);border-radius:4px"></div>
            <div style="width:60px;height:12px;background:var(--paper-2);border-radius:4px"></div>
            <div style="width:70px;height:12px;background:var(--paper-2);border-radius:4px"></div>
            <div style="width:76px;height:28px;background:var(--paper-2);border-radius:6px"></div>
          </div>
        ))}
      </div>

      <!-- Error state (hidden by default) -->
      <div id="error-state" style="display:none;padding:48px;text-align:center;flex-direction:column;gap:12px;align-items:center">
        <div style="font-family:var(--font-mono);font-size:11px;color:var(--error);letter-spacing:.08em;text-transform:uppercase">error</div>
        <div style="font-family:var(--font-sans);font-size:16px;font-weight:600">Couldn't reach the catalog index</div>
        <div style="font-size:13px;color:var(--muted);max-width:420px;line-height:1.5">
          The catalog couldn't fetch <code class="mono">profiles/index.json</code> from the registry. Check your connection or try again.
        </div>
        <button id="retry-btn" style="font:inherit;font-family:var(--font-sans);font-size:13px;font-weight:500;padding:8px 16px;border:1px solid var(--border);border-radius:var(--r-md);background:var(--surface-raised);color:var(--ink);cursor:pointer;margin-top:8px">Retry</button>
      </div>

      <!-- No results (hidden by default) -->
      <div id="no-results" style="display:none;padding:48px;text-align:center;color:var(--muted);font-family:var(--font-sans);font-size:14px">
        No profiles match these filters. <a href={base + "/contribute"} style="color:var(--primary);text-decoration:underline">Open a PR for this combo →</a>
      </div>
    </main>
  </div>

  <!-- Filter drawer backdrop (mobile only) -->
  <div id="filter-backdrop" hidden style="position:fixed;inset:0;background:rgba(0,0,0,0.3);z-index:29"></div>

  <!-- Compare tray bar (hidden when <2 checked) -->
  <div id="compare-tray" style="display:none;position:sticky;bottom:16px;margin:0 32px 16px;background:var(--surface-float);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border:1px solid var(--border);border-radius:8px;padding:12px 16px;align-items:center;gap:16px;box-shadow:var(--shadow-float);z-index:5">
    <span class="eyebrow">Compare · <span id="compare-count">0</span></span>
    <div id="compare-chips" style="display:flex;gap:8px;flex:1;min-width:0;overflow:hidden"></div>
    <button id="compare-clear" style="font:inherit;background:transparent;border:0;cursor:pointer;font-family:var(--font-sans);font-size:13px;color:var(--muted)">Clear</button>
    <button id="compare-open" style="font:inherit;font-family:var(--font-sans);font-size:13px;font-weight:600;padding:8px 16px;border:0;border-radius:var(--r-md);background:var(--ink);color:var(--paper);cursor:pointer">Compare →</button>
  </div>

  <!-- Compare overlay (full comparison grid) -->
  <div id="compare-overlay" style="display:none;position:fixed;inset:0;z-index:20">
    <div id="compare-backdrop" style="position:absolute;inset:0;background:rgba(0,0,0,0.3)"></div>
    <div id="compare-sheet" style="position:absolute;bottom:0;left:0;right:0;max-height:85vh;background:var(--paper);border-top:1px solid var(--border);border-radius:var(--r-lg) var(--r-lg) 0 0;box-shadow:var(--shadow-float);display:flex;flex-direction:column;overflow:hidden;transform:translateY(100%);transition:transform var(--d-medium) var(--ease-enter)">
      <div style="display:flex;align-items:center;justify-content:space-between;padding:16px 24px;border-bottom:1px solid var(--border);flex-shrink:0">
        <span class="eyebrow">compare · <span id="compare-sheet-count">0</span> profile<span id="compare-sheet-plural">s</span></span>
        <button id="compare-close" style="font:inherit;background:transparent;border:0;cursor:pointer;font-family:var(--font-sans);font-size:20px;color:var(--muted);padding:4px 8px;line-height:1" aria-label="Close compare">×</button>
      </div>
      <div id="compare-grid-wrap" style="overflow:auto;padding:24px;flex:1">
        <div id="compare-grid"></div>
        <div id="compare-actions" style="display:flex;gap:12px;justify-content:flex-end;margin-top:24px"></div>
      </div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{
  profilesJson: JSON.stringify(PROFILES.map(p => ({
    id: p.id, name: p.name, fit: p.fit, backend: p.backend,
    hardware: p.hardware, os: p.os, useCase: p.useCase,
    tags: p.tags || [], modelOrg: p.modelOrg, profileOrg: p.profileOrg,
    verified: p.verified, updated: p.updated, args: p.args || [],
    env: p.env || [], maintainer: p.maintainer, importCmd: p.importCmd,
  }))),
  base: import.meta.env.BASE_URL
}}>
  var FALLBACK_PROFILES = JSON.parse(profilesJson);
  var PROFILES = [];
  var search = document.getElementById("search");
  var sort = document.getElementById("sort");
  var noResults = document.getElementById("no-results");
  var errorState = document.getElementById("error-state");
  var countEl = document.getElementById("count");
  var resultsContainer = document.getElementById("results");
  var retryBtn = document.getElementById("retry-btn");
  var tray = document.getElementById("compare-tray");
  var trayChips = document.getElementById("compare-chips");
  var trayCount = document.getElementById("compare-count");
  var trayClear = document.getElementById("compare-clear");
  var trayOpen = document.getElementById("compare-open");
  var overlay = document.getElementById("compare-overlay");
  var overlayBackdrop = document.getElementById("compare-backdrop");
  var overlayClose = document.getElementById("compare-close");
  var overlaySheet = document.getElementById("compare-sheet");
  var overlayGrid = document.getElementById("compare-grid");
  var overlayActions = document.getElementById("compare-actions");
  var overlayCount = document.getElementById("compare-sheet-count");
  var overlayPlural = document.getElementById("compare-sheet-plural");
  var COMPARE_MIN = 2;
  var compareIds = [];
  var focusedRowIndex = -1;

  function visibleRowEls() {
    var rows = Array.from(document.querySelectorAll(".result-row"));
    return rows.filter(function(r) { return r.style.display !== "none"; });
  }

  function clearRowFocus() {
    var rows = Array.from(document.querySelectorAll(".result-row"));
    rows.forEach(function(r) { r.classList.remove("keyboard-focused"); });
    focusedRowIndex = -1;
  }

  function focusRow(index) {
    var visible = visibleRowEls();
    if (visible.length === 0) return;
    var target = index;
    if (target < 0) target = visible.length - 1;
    if (target >= visible.length) target = 0;
    clearRowFocus();
    focusedRowIndex = target;
    visible[target].classList.add("keyboard-focused");
    visible[target].scrollIntoView({ block: "nearest", behavior: "smooth" });
  }

  function openFocusedProfile() {
    if (focusedRowIndex < 0) return;
    var visible = visibleRowEls();
    if (focusedRowIndex >= visible.length) return;
    var link = visible[focusedRowIndex].querySelector("a");
    if (link) window.location.href = link.href;
  }
  var activeFilters = {
    backend: new Set(),
    hardware: new Set(),
    os: new Set(),
    useCase: new Set(),
    modelOrg: new Set(),
    profileOrg: new Set(),
    tags: new Set(),
    source: new Set(),
  };

  var STORAGE_KEY = "browse-state";

  function saveState() {
    var state = { filters: {}, sort: sort.value, search: search.value };
    Object.keys(activeFilters).forEach(function(k) {
      state.filters[k] = Array.from(activeFilters[k]);
    });
    try { sessionStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch(e) {}
  }

  function restoreState() {
    try {
      var raw = sessionStorage.getItem(STORAGE_KEY);
      if (!raw) return false;
      var state = JSON.parse(raw);
      if (state.filters) {
        Object.keys(state.filters).forEach(function(k) {
          if (activeFilters[k]) {
            activeFilters[k] = new Set(state.filters[k]);
          }
        });
      }
      if (state.sort) sort.value = state.sort;
      if (state.search) {
        search.value = state.search;
        var sm = document.getElementById("search-mobile");
        if (sm) sm.value = state.search;
      }
      return true;
    } catch(e) { return false; }
  }

  function applyFilterButtonStyles() {
    document.querySelectorAll(".filter-opt").forEach(function(btn) {
      var group = btn.dataset.group;
      var value = btn.dataset.value;
      var active = activeFilters[group] && activeFilters[group].has(value);
      btn.style.color = active ? "var(--ink)" : "var(--muted)";
      btn.style.fontWeight = active ? "600" : "400";
      btn.querySelector(".filter-dot").style.background = active ? "var(--primary)" : "transparent";
    });
  }

  function updateTray() {
    var items = compareIds.map(function(id) { return PROFILES.find(function(p) { return p.id === id; }); }).filter(Boolean);
    if (items.length < 2) {
      tray.style.display = "none";
    } else {
      tray.style.display = "flex";
      trayCount.textContent = String(items.length);
      trayChips.innerHTML = items.map(function(p) { return '<span style="border:1px solid var(--border);padding:3px 8px;border-radius:4px;background:var(--paper);font-family:var(--font-sans);font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:180px">' + p.name + '</span>'; }).join("");
    }
  }

  function isDifferent(row, items) {
    if (items.length < 2) return false;
    var seen = new Set();
    for (var i = 0; i < items.length; i++) {
      var v = row.get(items[i]);
      seen.add(typeof v === "string" ? v : JSON.stringify(items[i][row.key] || ""));
      if (seen.size > 1) return true;
    }
    return false;
  }

  function renderCompareGrid(items) {
    var rows = [
      { label: "Backend", get: function(p) { return p.backend; }, mono: true, key: "backend" },
      { label: "Hardware", get: function(p) { return p.hardware; }, mono: true, key: "hardware" },
      { label: "Operating system", get: function(p) { return p.os; }, mono: true, key: "os" },
      { label: "Use case", get: function(p) { return p.useCase; }, mono: false, key: "useCase" },
      { label: "Source", get: function(p) { return p.verified ? "✓ Verified" : "Community"; }, mono: true, key: "source" },
      { label: "Maintainer", get: function(p) { return p.maintainer; }, mono: true, key: "maintainer" },
      { label: "Last updated", get: function(p) { return p.updated; }, mono: true, key: "updated" },
      { label: "Args", get: function(p) { return p.args && p.args.length ? p.args.join(", ") : "—"; }, mono: true, key: "args" },
      { label: "Env", get: function(p) { return p.env && p.env.length ? p.env.map(function(e) { return e.key + "=" + e.value; }).join(", ") : "—"; }, mono: true, key: "env" },
      { label: "Import command", get: function(p) { return p.importCmd; }, mono: true, key: "importCmd" },
    ];

    var w = items.length;
    var html = '<div style="display:grid;grid-template-columns:180px repeat(' + w + ', minmax(0, 1fr));border:1px solid var(--border);border-radius:var(--r-md);overflow:hidden;background:var(--surface-raised)">';

    html += '<div style="background:var(--paper-2);border-bottom:1px solid var(--border);padding:16px"></div>';
    for (var i = 0; i < items.length; i++) {
      html += '<div style="background:var(--paper-2);border-bottom:1px solid var(--border);border-left:1px solid var(--border);padding:16px;display:flex;flex-direction:column;gap:6px">';
      html += '<a href="' + base + '/profile/' + items[i].id + '" style="font:inherit;background:transparent;border:0;text-align:left;cursor:pointer;font-family:var(--font-sans);font-size:16px;font-weight:600;color:var(--ink);line-height:1.3;text-decoration:none">' + items[i].name + '</a>';
      html += '<span style="font-family:var(--font-sans);font-size:13px;color:var(--muted);line-height:1.4">' + (items[i].fit || "") + '</span>';
      html += '</div>';
    }

    for (var ri = 0; ri < rows.length; ri++) {
      var row = rows[ri];
      var diff = isDifferent(row, items);
      var isLast = ri === rows.length - 1;
      var borderBottom = isLast ? "0" : "1px solid var(--border)";
      html += '<div class="' + (diff ? "compare-diff" : "") + '" style="border-bottom:' + borderBottom + ';padding:14px 16px;font-family:var(--font-mono);font-size:11px;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;display:flex;align-items:flex-start;padding-top:16px">' + row.label + '</div>';
      for (var j = 0; j < items.length; j++) {
        html += '<div class="' + (diff ? "compare-diff" : "") + '" style="border-bottom:' + borderBottom + ';border-left:1px solid var(--border);padding:14px 16px;font-family:' + (row.mono ? "var(--font-mono)" : "var(--font-sans)") + ';font-size:' + (row.mono ? 13 : 14) + 'px;color:var(--ink);line-height:1.5;min-width:0;overflow:hidden">' + row.get(items[j]) + '</div>';
      }
    }

    html += '</div>';
    return html;
  }

  function openCompare() {
    var items = compareIds.map(function(id) { return PROFILES.find(function(p) { return p.id === id; }); }).filter(Boolean);
    if (items.length < 2) return;

    overlayCount.textContent = String(items.length);
    overlayPlural.textContent = items.length === 1 ? "" : "s";
    overlayGrid.innerHTML = renderCompareGrid(items);

    var actionsHtml = '';
    for (var i = 0; i < items.length; i++) {
      actionsHtml += '<a href="' + base + '/profile/' + items[i].id + '" style="font:inherit;font-family:var(--font-sans);font-size:13px;font-weight:600;padding:8px 16px;border:1px solid var(--border);border-radius:var(--r-md);background:transparent;color:var(--ink);cursor:pointer;text-decoration:none;display:inline-block">Open ' + items[i].name.split(" — ")[0] + ' →</a>';
    }
    overlayActions.innerHTML = actionsHtml;

    overlay.style.display = "block";
    overlaySheet.offsetHeight;
    overlaySheet.style.transform = "translateY(0)";
    document.body.style.overflow = "hidden";
  }

  function closeCompare() {
    overlaySheet.style.transform = "translateY(100%)";
    setTimeout(function() {
      overlay.style.display = "none";
      document.body.style.overflow = "";
    }, 280);
  }

  function applyFilters() {
    clearRowFocus();
    var q = search.value.trim().toLowerCase();
    var terms = q ? q.split(/\s+/).filter(Boolean) : [];
    var sortVal = sort.value;
    var rows = Array.from(document.querySelectorAll(".result-row"));

    var visible = rows.filter(function(row) {
      if (activeFilters.backend.size && !activeFilters.backend.has(row.dataset.backend)) return false;
      if (activeFilters.hardware.size && !activeFilters.hardware.has(row.dataset.hardware)) return false;
      if (activeFilters.os.size && !activeFilters.os.has(row.dataset.os)) return false;
      if (activeFilters.useCase.size && !activeFilters.useCase.has(row.dataset.usecase)) return false;
      if (activeFilters.tags.size) {
        var rowTags = (row.dataset.tags || "").split(",").filter(Boolean);
        if (!rowTags.some(function(t) { return activeFilters.tags.has(t); })) return false;
      }
      if (activeFilters.modelOrg.size && !activeFilters.modelOrg.has(row.dataset.modelOrg)) return false;
      if (activeFilters.profileOrg.size && !activeFilters.profileOrg.has(row.dataset.profileOrg)) return false;
      if (activeFilters.source.size) {
        var tag = row.dataset.verified === "true" ? "Verified" : "Community";
        if (!activeFilters.source.has(tag)) return false;
      }
      if (terms.length) {
        var blob = (row.dataset.name + " " + row.dataset.backend + " " + row.dataset.hardware + " " + row.dataset.os + " " + (row.dataset.usecase || "") + " " + (row.dataset.tags || "") + " " + (row.dataset.modelOrg || "") + " " + (row.dataset.profileOrg || "")).toLowerCase();
        for (var i = 0; i < terms.length; i++) {
          if (blob.indexOf(terms[i]) === -1) return false;
        }
      }
      return true;
    });

    if (sortVal === "Updated") {
      visible.sort(function(a, b) { return Number(a.dataset.index) - Number(b.dataset.index); });
    } else if (sortVal === "Name") {
      visible.sort(function(a, b) { return (a.dataset.name || "").localeCompare(b.dataset.name || ""); });
    } else if (sortVal === "Fit") {
      visible.sort(function(a, b) {
        return (Number(b.dataset.verified === "true") - Number(a.dataset.verified === "true")) ||
               (a.dataset.name || "").localeCompare(b.dataset.name || "");
      });
    }

    rows.forEach(function(r) { r.style.display = "none"; });
    visible.forEach(function(r) {
      r.style.display = "grid";
      resultsContainer.appendChild(r);
    });

    noResults.style.display = visible.length ? "none" : "block";
    countEl.innerHTML = '<strong>' + visible.length + '</strong> <span style="color:var(--muted)">of ' + PROFILES.length + ' profiles</span>';
  }

  // --- Data fetching and state management ---

  function rowHTML(p, idx) {
    var verifiedBadge = p.verified ? '<span style="font-family:var(--font-mono);font-size:11px;color:var(--success);flex:0 0 auto;white-space:nowrap">✓</span>' : '';
    return '<div class="result-row" data-index="' + idx + '" data-backend="' + p.backend + '" data-hardware="' + p.hardware + '" data-os="' + p.os + '" data-usecase="' + p.useCase + '" data-tags="' + (p.tags || []).join(",") + '" data-model-org="' + p.modelOrg + '" data-profile-org="' + p.profileOrg + '" data-verified="' + String(p.verified) + '" data-name="' + p.name + '" style="border-bottom:1px solid var(--border);padding:14px 0;display:grid;grid-template-columns:20px 1fr 120px 130px 100px 100px 110px;gap:16px;align-items:center">' +
      '<input type="checkbox" class="compare-check" data-id="' + p.id + '" style="accent-color:var(--primary);width:16px;height:16px" />' +
      '<a href="' + base + '/profile/' + p.id + '" style="font:inherit;background:transparent;border:0;text-align:left;cursor:pointer;padding:0;min-width:0;text-decoration:none;color:inherit">' +
        '<div style="display:flex;align-items:flex-start;gap:8px;flex-wrap:wrap">' +
          '<strong style="font-family:var(--font-sans);font-size:15px;flex:1 1 auto;min-width:0">' + p.name + '</strong>' +
          verifiedBadge +
        '</div>' +
        '<div style="font-size:13px;color:var(--ink);margin-top:2px">' + p.fit + '</div>' +
      '</a>' +
      '<span class="meta-line" style="font-family:var(--font-mono);font-size:12px;color:var(--muted)">' + p.backend + ' · ' + p.hardware + ' · ' + p.os + '</span>' +
      '<span class="updated-span" style="font-family:var(--font-mono);font-size:12px;color:var(--muted)">' + p.updated + '</span>' +
      '<a href="' + base + '/profile/' + p.id + '" class="import-btn" style="font:inherit;font-family:var(--font-sans);font-size:13px;font-weight:600;padding:6px 12px;border:0;border-radius:var(--r-md);background:var(--primary);color:#fff;cursor:pointer;text-decoration:none;text-align:center;display:inline-block">Import</a>' +
    '</div>';
  }

  function renderAllRows() {
    var html = "";
    for (var i = 0; i < PROFILES.length; i++) {
      html += rowHTML(PROFILES[i], i);
    }
    resultsContainer.innerHTML = html;
  }

  function showSkeleton() {
    var html = "";
    for (var i = 0; i < 4; i++) {
      html += '<div class="skeleton-row" style="border-bottom:1px solid var(--border);padding:14px 0;display:grid;grid-template-columns:20px 1fr 120px 130px 100px 100px 110px;gap:16px;align-items:center">' +
        '<div style="width:16px;height:16px;border-radius:2px;background:var(--paper-2)"></div>' +
        '<div>' +
          '<div style="width:55%;height:14px;background:var(--paper-2);border-radius:4px"></div>' +
          '<div style="width:78%;height:12px;background:var(--paper-2);border-radius:4px;margin-top:8px"></div>' +
        '</div>' +
        '<div style="width:70px;height:12px;background:var(--paper-2);border-radius:4px"></div>' +
        '<div style="width:90px;height:12px;background:var(--paper-2);border-radius:4px"></div>' +
        '<div style="width:60px;height:12px;background:var(--paper-2);border-radius:4px"></div>' +
        '<div style="width:70px;height:12px;background:var(--paper-2);border-radius:4px"></div>' +
        '<div style="width:76px;height:28px;background:var(--paper-2);border-radius:6px"></div>' +
      '</div>';
    }
    resultsContainer.innerHTML = html;
  }

  function showError() {
    resultsContainer.style.display = "none";
    errorState.style.display = "flex";
    noResults.style.display = "none";
    countEl.innerHTML = '<strong style="color:var(--error)">—</strong> <span style="color:var(--muted)">of — profiles</span>';
  }

  function hideError() {
    errorState.style.display = "none";
    resultsContainer.style.display = "";
  }

  async function fetchProfiles() {
    var resp = await fetch(base + "profiles/index.json");
    if (!resp.ok) throw new Error("HTTP " + resp.status);
    PROFILES = await resp.json();
  }

  async function loadProfiles() {
    showSkeleton();
    errorState.style.display = "none";
    resultsContainer.style.display = "";
    try {
      await fetchProfiles();
    } catch (e) {
      // Fetch failed — fall back to inline data (always available from build).
      PROFILES = FALLBACK_PROFILES;
    }
    if (PROFILES.length === 0) {
      showError();
      return;
    }
    hideError();
    renderAllRows();
    var didRestore = restoreState();
    if (didRestore) {
      applyFilterButtonStyles();
      applyFilters();
    }
    updateFilterBadge();
  }

  retryBtn.addEventListener("click", loadProfiles);

  // --- Event listeners ---

  document.querySelectorAll(".filter-opt").forEach(function(btn) {
    btn.addEventListener("click", function() {
      var group = btn.dataset.group;
      var value = btn.dataset.value;
      var set = activeFilters[group];
      if (set.has(value)) set.delete(value); else set.add(value);
      var active = set.has(value);
      btn.style.color = active ? "var(--ink)" : "var(--muted)";
      btn.style.fontWeight = active ? "600" : "400";
      btn.querySelector(".filter-dot").style.background = active ? "var(--primary)" : "transparent";
      saveState();
      applyFilters();
    });
  });

  // --- Filter drawer (mobile) ---
  var filterToggle = document.getElementById("filter-toggle");
  var filterCloseBtn = document.getElementById("filter-close");
  var filterApplyBtn = document.getElementById("filter-apply");
  var filterBackdrop = document.getElementById("filter-backdrop");
  var filterClearAll = document.getElementById("filter-clear-all");
  var filtersAside = document.getElementById("filters");
  var filterCountBadge = document.getElementById("filter-count-badge");

  function activeFilterCount() {
    return Object.keys(activeFilters).reduce(function(n, k) { return n + activeFilters[k].size; }, 0);
  }

  function updateFilterBadge() {
    var n = activeFilterCount();
    if (n > 0) {
      filterCountBadge.textContent = String(n);
      filterCountBadge.hidden = false;
    } else {
      filterCountBadge.hidden = true;
    }
  }

  function openDrawer() {
    filtersAside.setAttribute("data-open", "true");
    filterBackdrop.hidden = false;
    filterToggle.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  function closeDrawer() {
    filtersAside.setAttribute("data-open", "false");
    filterBackdrop.hidden = true;
    filterToggle.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  filterToggle.addEventListener("click", openDrawer);
  filterCloseBtn.addEventListener("click", closeDrawer);
  filterApplyBtn.addEventListener("click", closeDrawer);
  filterBackdrop.addEventListener("click", closeDrawer);

  filterClearAll.addEventListener("click", function() {
    Object.keys(activeFilters).forEach(function(k) { activeFilters[k].clear(); });
    applyFilterButtonStyles();
    updateFilterBadge();
    saveState();
    applyFilters();
  });

  // Update badge whenever any filter is toggled
  document.querySelectorAll(".filter-opt").forEach(function(btn) {
    btn.addEventListener("click", updateFilterBadge);
  });
  updateFilterBadge();

  // Escape closes filter drawer
  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape" && filtersAside.getAttribute("data-open") === "true") {
      e.preventDefault();
      closeDrawer();
    }
  });

  // Auto-close drawer when viewport widens past mobile breakpoint
  var mqDesktop = window.matchMedia("(min-width: 701px)");
  mqDesktop.addEventListener("change", function(e) {
    if (e.matches) closeDrawer();
  });

  search.addEventListener("input", function() {
    if (searchMobile && searchMobile.value !== search.value) searchMobile.value = search.value;
    saveState();
    applyFilters();
  });
  var searchMobile = document.getElementById("search-mobile");
  if (searchMobile) {
    searchMobile.addEventListener("input", function() {
      search.value = searchMobile.value;
      saveState();
      applyFilters();
    });
  }
  sort.addEventListener("change", function() { saveState(); applyFilters(); });

  // Event delegation for compare checkboxes (rows are dynamically rendered)
  resultsContainer.addEventListener("change", function(e) {
    if (!e.target.classList.contains("compare-check")) return;
    var id = e.target.dataset.id;
    if (e.target.checked) {
      compareIds.push(id);
    } else {
      compareIds = compareIds.filter(function(x) { return x !== id; });
    }
    updateTray();
  });

  trayClear.addEventListener("click", function() {
    compareIds = [];
    document.querySelectorAll(".compare-check").forEach(function(c) { c.checked = false; });
    updateTray();
  });

  trayOpen.addEventListener("click", openCompare);
  overlayClose.addEventListener("click", closeCompare);
  overlayBackdrop.addEventListener("click", closeCompare);

  document.addEventListener("keydown", function(e) {
    // Don't intercept when shortcuts overlay is open (global handler owns it)
    var shortcutsOverlay = document.getElementById("shortcuts-overlay");
    if (shortcutsOverlay && shortcutsOverlay.style.display === "block") return;

    if (e.key === "Escape" && overlay.style.display === "block") {
      e.preventDefault();
      closeCompare();
      return;
    }

    // Don't intercept row nav when compare overlay is open
    if (overlay.style.display === "block") return;

    // Ignore when focus is in a form control or button (except for Escape)
    var tag = e.target.tagName;
    if (tag === "INPUT" || tag === "SELECT" || tag === "TEXTAREA" || tag === "BUTTON") {
      if (e.key === "Escape" && document.activeElement === search) {
        search.blur();
        return;
      }
      return;
    }

    // Don't intercept modified keystrokes (Ctrl+C, Cmd+J, etc.)
    if (e.ctrlKey || e.metaKey || e.altKey) return;

    if (e.key === "/") {
      e.preventDefault();
      search.focus();
      return;
    }

    if (e.key === "j") {
      e.preventDefault();
      focusRow(focusedRowIndex + 1);
      return;
    }

    if (e.key === "k") {
      e.preventDefault();
      if (focusedRowIndex === -1) {
        focusRow(0);
      } else {
        focusRow(focusedRowIndex - 1);
      }
      return;
    }

    if (e.key === "Enter" && focusedRowIndex >= 0) {
      e.preventDefault();
      openFocusedProfile();
      return;
    }

    if (e.key === " " && focusedRowIndex >= 0) {
      e.preventDefault();
      var visible = visibleRowEls();
      if (focusedRowIndex < visible.length) {
        var cb = visible[focusedRowIndex].querySelector(".compare-check");
        if (cb) {
          cb.checked = !cb.checked;
          cb.dispatchEvent(new Event("change", { bubbles: true }));
        }
      }
      return;
    }

    if (e.key === "c") {
      e.preventDefault();
      if (compareIds.length >= COMPARE_MIN) openCompare();
      return;
    }
  });

  var style = document.createElement("style");
  style.textContent = ".result-row.keyboard-focused { background: var(--paper-2); box-shadow: inset 3px 0 0 var(--primary); }" +
    ".import-btn { padding: 6px 12px !important; font-size: 13px !important; }" +
    ".compare-diff { background: rgba(47,107,255,0.10) !important; }" +
    "[data-theme=\"dark\"] .compare-diff { background: rgba(77,125,255,0.18) !important; }";
  document.head.appendChild(style);

  // Kick off the fetch on page load
  loadProfiles();
</script>

<style is:global>
  /* ---- browse page mobile (≤700px) ---- */
  @media (max-width: 700px) {
    /* ---- Page chrome ---- */
    body > section:first-of-type {
      padding: 20px 16px !important;
    }
    body > section:first-of-type h1 {
      font-size: 26px !important;
    }
    body > section:first-of-type p {
      font-size: 14px !important;
    }
    [style*="font-size:40px"] {
      font-size: 26px !important;
    }

    /* ---- Layout: single column ---- */
    [style*="grid-template-columns:220px 1fr"] {
      grid-template-columns: 1fr !important;
      gap: 0 !important;
      padding: 0 16px 16px !important;
    }

    /* ---- Show mobile-only elements ---- */
    .mobile-only { display: flex !important; }
    #filter-toggle-bar.mobile-only { display: flex !important; }
    #filter-count-badge:not([hidden]) { display: inline-flex !important; }
    #filter-drawer-footer.mobile-only { display: flex !important; }

    /* ---- Hide desktop elements ---- */
    .search-shortcut { display: none !important; }
    main > div:nth-of-type(2) { display: none !important; } /* column header row */

    /* ---- Filter drawer ---- */
    #filters {
      position: fixed !important;
      top: 0 !important;
      right: 0 !important;
      bottom: 0 !important;
      width: min(360px, 88vw) !important;
      background: var(--paper) !important;
      border-left: 1px solid var(--border) !important;
      box-shadow: var(--shadow-float) !important;
      z-index: 30 !important;
      transform: translateX(100%) !important;
      transition: transform var(--d-medium) var(--ease-enter) !important;
      overflow-y: auto !important;
      padding: 24px 20px !important;
      flex-direction: column !important;
      gap: 20px !important;
      display: flex !important;
    }
    #filters[data-open="true"] {
      transform: translateX(0) !important;
    }
    #filters .filter-group {
      flex: none !important;
      min-width: 0 !important;
    }
    #search {
      width: 100% !important;
    }

    /* ---- Cards (replace table on mobile) ---- */
    main {
      overflow-x: visible !important;
    }

    .result-row {
      display: flex !important;
      flex-direction: column !important;
      gap: 8px !important;
      grid-template-columns: none !important;
      padding: 16px !important;
      border: 1px solid var(--border) !important;
      border-radius: var(--r-md) !important;
      margin-bottom: 12px !important;
      min-width: 0 !important;
      background: var(--surface-raised) !important;
    }
    /* Respect JS-set inline display:none for filtered-out rows.
       The attribute selector wins on specificity over .result-row's !important. */
    .result-row[style*="display: none"],
    .result-row[style*="display:none"] {
      display: none !important;
    }

    /* Checkbox -- top-left of card */
    .result-row > input.compare-check {
      order: 1;
      align-self: flex-start;
      width: 20px !important;
      height: 20px !important;
    }

    /* Name + fit link -- full width */
    .result-row > a:first-of-type {
      order: 2;
      width: 100%;
    }
    .result-row > a:first-of-type strong {
      font-size: 16px !important;
      word-break: break-word !important;
      line-height: 1.3 !important;
    }
    .result-row > a:first-of-type > div:last-of-type {
      font-size: 14px !important;
      color: var(--muted) !important;
      margin-top: 4px !important;
    }

    /* Meta line -- backend / hardware / os */
    .result-row > .meta-line {
      order: 3;
      font-size: 12px !important;
      color: var(--muted) !important;
    }

    /* Updated date */
    .result-row > .updated-span {
      order: 4;
      font-size: 12px !important;
      color: var(--muted) !important;
    }

    /* Import button -- full width */
    .result-row > a.import-btn {
      order: 5;
      width: 100% !important;
      box-sizing: border-box !important;
      padding: 12px 16px !important;
      font-size: 14px !important;
      text-align: center;
      margin-top: 8px;
    }

    /* ---- Count + sort bar ---- */
    main > div:first-of-type {
      flex-wrap: wrap !important;
      gap: 8px !important;
      min-width: 0 !important;
    }
    /* Breathing room between the count/sort divider and the first card */
    #results {
      margin-top: 16px !important;
    }

    /* ---- Compare tray -- full-width sticky ---- */
    #compare-tray {
      flex-wrap: wrap !important;
      gap: 8px !important;
      margin: 0 !important;
      border-radius: 0 !important;
      border-left: 0 !important;
      border-right: 0 !important;
      padding: 12px 16px !important;
      bottom: 0 !important;
    }
    #compare-tray .eyebrow {
      width: 100% !important;
    }
    #compare-chips {
      flex-wrap: nowrap !important;
      overflow-x: auto !important;
      -webkit-overflow-scrolling: touch !important;
    }
    #compare-open {
      flex: 1 1 100% !important;
      order: 99;
      padding: 12px !important;
      font-size: 14px !important;
    }

    /* ---- Compare overlay -- full-width ---- */
    #compare-sheet {
      max-height: 95vh !important;
      border-radius: var(--r-lg) var(--r-lg) 0 0 !important;
    }
    #compare-grid-wrap {
      padding: 12px !important;
    }
    [style*="grid-template-columns:180px repeat"] {
      display: block !important;
      overflow-x: auto !important;
    }
  }

  /* ---- browse page tablet (701–1024px) ---- */
  @media (min-width: 701px) and (max-width: 1024px) {
    /* Narrower filter sidebar */
    [style*="grid-template-columns:220px 1fr"] {
      grid-template-columns: 170px 1fr !important;
      gap: 24px !important;
    }
    /* Slightly reduce heading */
    body > section:first-of-type h1 {
      font-size: 34px !important;
    }
    /* Results table — allow horizontal scroll at tablet (7 cols won't fit) */
    main {
      overflow-x: auto !important;
      -webkit-overflow-scrolling: touch !important;
    }
    .result-row,
    [style*="grid-template-columns:20px 1fr 120px 130px 100px 100px 110px"] {
      min-width: 600px !important;
    }
  }

  /* ---- Mobile-only elements (hidden on desktop) ---- */
  .mobile-only { display: none; }
</style>

---
// compare.astro — Side-by-side profile comparison.
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import { PROFILES } from "../data/profiles";

const base = import.meta.env.BASE_URL;

// Get IDs from query string
const url = new URL(Astro.request.url);
const ids = (url.searchParams.get("ids") || "").split(",").filter(Boolean);
const items = ids.map((id: string) => PROFILES.find((p) => p.id === id)).filter(Boolean);

const rows = items.length === 0 ? [] : [
  { label: "Backend", get: (p: any) => p.backend, mono: true },
  { label: "Hardware", get: (p: any) => p.hardware, mono: true },
  { label: "Operating system", get: (p: any) => p.os, mono: true },
  { label: "Use case", get: (p: any) => p.useCase, mono: false },
  { label: "Source", get: (p: any) => p.verified ? "✓ Verified" : "Community", mono: true },
  { label: "Maintainer", get: (p: any) => p.maintainer, mono: true },
  { label: "Last updated", get: (p: any) => p.updated, mono: true },
  { label: "Args", get: (p: any) => p.args.length ? p.args.join(", ") : "—", mono: true },
  { label: "Env", get: (p: any) => p.env.length ? p.env.map((e: any) => `${e.key}=${e.value}`).join(", ") : "—", mono: true },
  { label: "Import command", get: (p: any) => p.importCmd, mono: true },
];

function isDifferent(row: any): boolean {
  if (items.length < 2) return false;
  const seen = new Set();
  for (const p of items) {
    const v = row.get(p);
    seen.add(typeof v === "string" ? v : JSON.stringify(p[row.label.toLowerCase()] || ""));
    if (seen.size > 1) return true;
  }
  return false;
}

const width = items.length;
---

<BaseLayout title="Compare profiles" description="Side-by-side comparison of selected profiles.">
  {items.length === 0 ? (
    <section style="padding:80px 32px;max-width:720px;margin:0 auto;text-align:center">
      <span class="eyebrow">compare</span>
      <h1 style="font-size:40px;letter-spacing:-0.01em;margin-top:8px">Nothing to compare yet</h1>
      <p style="color:var(--muted);font-size:15px;line-height:1.6;margin-top:8px">
        Pick two or more profiles in <strong>Browse</strong> to see them side-by-side.
      </p>
      <div style="margin-top:20px">
        <Button href={`${base}/browse`}>Open browse →</Button>
      </div>
    </section>
  ) : (
    <>
      <section style="border-bottom:1px solid var(--border);padding:32px">
        <div style="max-width:1280px;margin:0 auto;display:flex;flex-direction:column;gap:12px">
          <a href={`${base}/browse`} style="font:inherit;background:transparent;border:0;padding:0;cursor:pointer;font-family:var(--font-mono);font-size:12px;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;text-align:left;width:fit-content;text-decoration:none">← back to browse</a>
          <span class="eyebrow">compare · {items.length} profile{items.length === 1 ? "" : "s"}</span>
          <h1 style="font-size:40px;letter-spacing:-0.01em;margin:0">Side-by-side</h1>
          <p style="color:var(--muted);font-size:15px;max-width:60ch;margin:0">
            Differences are highlighted. Pick the profile that fits best, then run its import command.
          </p>
        </div>
      </section>

      <section style="padding:32px;max-width:1280px;margin:0 auto">
        <div style={`display:grid;grid-template-columns:180px repeat(${width}, minmax(0, 1fr));border:1px solid var(--border);border-radius:8px;overflow:hidden;background:var(--surface-raised)`}>
          <!-- Header row -->
          <div style="background:var(--paper-2);border-bottom:1px solid var(--border);padding:16px"></div>
          {items.map((p: any) => (
            <div style="background:var(--paper-2);border-bottom:1px solid var(--border);border-left:1px solid var(--border);padding:16px;display:flex;flex-direction:column;gap:6px">
              <a href={`${base}/profile/${p.id}`} style="font:inherit;background:transparent;border:0;text-align:left;cursor:pointer;font-family:var(--font-sans);font-size:16px;font-weight:600;color:var(--ink);line-height:1.3;text-decoration:none">
                {p.name}
              </a>
              <span style="font-family:var(--font-sans);font-size:13px;color:var(--muted);line-height:1.4">{p.fit}</span>
            </div>
          ))}

          {/* Data rows */}
          {rows.map((row: any, ri: number) => {
            const diff = isDifferent(row);
            return (
              <>
                <div style={`border-bottom:${ri === rows.length - 1 ? "0" : "1px solid var(--border)"};padding:14px 16px;background:${diff ? "rgba(47,107,255,.04)" : "transparent"};font-family:var(--font-mono);font-size:11px;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;display:flex;align-items:flex-start;padding-top:16px`}>
                  {row.label}
                </div>
                {items.map((p: any) => (
                  <div style={`border-bottom:${ri === rows.length - 1 ? "0" : "1px solid var(--border)"};border-left:1px solid var(--border);padding:14px 16px;background:${diff ? "rgba(47,107,255,.04)" : "transparent"};font-family:${row.mono ? "var(--font-mono)" : "var(--font-sans)"};font-size:${row.mono ? 13 : 14}px;color:var(--ink);line-height:1.5;min-width:0;overflow:hidden`}>
                    {row.get(p)}
                  </div>
                ))}
              </>
            );
          })}
        </div>

        <div style="margin-top:24px;display:flex;gap:12px;justify-content:flex-end">
          {items.map((p: any) => (
            <Button variant="secondary" href={`${base}/profile/${p.id}`}>
              Open {p.name.split(" — ")[0]} →
            </Button>
          ))}
        </div>
      </section>
    </>
  )}
</BaseLayout>

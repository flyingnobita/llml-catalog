---
// contribute.astro — Contribute / how it works / docs page.
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
import Badge from "../components/Badge.astro";
import { tomlSample } from "../data/toml-examples";

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Contribute"
  description="A profile is a setup, not a model card. Share the args your machine and model converged on."
>
  <!-- Hero -->
  <section style="border-bottom:1px solid var(--border);padding:48px 32px">
    <div style="max-width:1180px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center">
      <div style="display:flex;flex-direction:column;gap:16px">
        <span class="eyebrow">contribute</span>
        <h1 style="font-size:48px;letter-spacing:-0.01em;margin:0">
          A profile is a <em style="font-style:italic">setup, not a model card</em>.
        </h1>
        <p style="font-size:17px;line-height:1.55;max-width:55ch;margin:0">
          The catalog is built from TOML files in a public GitHub repo. If you've gotten a model running well on your machine,
          the args and env you used are exactly what someone with the same machine needs.
        </p>
        <div style="display:flex;gap:12px;margin-top:8px">
          <Button variant="primary" href="https://github.com/flyingnobita/llml-catalog">Open a PR ↗</Button>
          <Button variant="secondary" href="https://github.com/flyingnobita/llml/blob/main/docs/profile-format.md">Read the schema</Button>
        </div>
      </div>
      <pre style="background:var(--surface-inverse);color:var(--surface-inverse-fg);padding:24px;border-radius:12px;font-size:12.5px;line-height:1.55;font-family:var(--font-mono);margin:0;overflow:auto;max-height:380px">{tomlSample}</pre>
    </div>
  </section>

  <!-- Content -->
  <section style="padding:56px 32px">
    <div style="max-width:1180px;margin:0 auto;display:grid;grid-template-columns:240px 1fr;gap:48px">
      <aside>
        <span class="eyebrow">Contents</span>
        <ol style="margin:12px 0 0;padding:0;list-style:none;display:flex;flex-direction:column;gap:6px;font-family:var(--font-sans);font-size:14px">
          {[
            { label: "What belongs in the catalog", id: "what-belongs-in-the-catalog" },
            { label: "What a strong profile includes", id: "what-a-strong-profile-includes" },
            { label: "Validation", id: "validation" },
            { label: "PR flow", id: "pr-flow" },
          ].map(({ label, id }, i) => (
            <li>
              <a
                href={`#${id}`}
                data-toc-link={id}
                aria-current={i === 0 ? "location" : undefined}
                style={`color:${i === 0 ? "var(--ink)" : "var(--muted)"};border-bottom:${i === 0 ? "1px solid var(--ink)" : "none"};text-decoration:none`}
              >
                {String(i + 1).padStart(2, "0")} · {label}
              </a>
            </li>
          ))}
        </ol>
      </aside>
      <article style="display:flex;flex-direction:column;gap:32px">
        <div id="what-belongs-in-the-catalog" class="contribute-section is-active">
          <h2 style="font-size:30px;margin:0 0 12px">What belongs in the catalog</h2>
          <p style="font-size:16px;line-height:1.6;max-width:62ch;margin:0">
            Profiles for <code class="mono">llama.cpp</code>, <code class="mono">vLLM</code>, <code class="mono">Ollama</code>, and{" "}
            <code class="mono">KoboldCpp</code>. One TOML file per profile, with a clear hardware target and a short
            rationale. Model-location parameters (<code class="mono">--model</code>, <code class="mono">HF_HOME</code>, etc.) are
            excluded — <code class="mono">llml</code> supplies them at launch.
          </p>
        </div>
        <div id="what-a-strong-profile-includes" class="contribute-section">
          <h2 style="font-size:30px;margin:0 0 12px">What a strong profile includes</h2>
          <ul style="margin:0;padding-left:18px;font-size:16px;line-height:1.7;max-width:62ch">
            <li>A <strong>name</strong> that reads as a setup, not a brand: <code class="mono">balanced-q4</code> beats <code class="mono">my-best-config</code>.</li>
            <li>Explicit <code class="mono">backend</code>, <code class="mono">hardware.class</code>, and tested VRAM range.</li>
            <li>A short <code class="mono">hardware.notes</code> line with the actual machine you tested on.</li>
            <li>Args as panel-row strings: <code class="mono">"--ctx-size 4096"</code>, not pre-split tokens.</li>
          </ul>
        </div>
        <div id="validation" class="contribute-section">
          <h2 style="font-size:30px;margin:0 0 12px">Validation</h2>
          <div style="border:1px solid var(--border);border-radius:8px;overflow:hidden;font-family:var(--font-mono);font-size:13px">
            {[
              ["schema_version == 2", "required"],
              ["backend ∈ {llama, vllm, ollama, koboldcpp}", "required"],
              ["use_case.primary ∈ canonical set", "warn"],
              ["model-location params absent from args", "required"],
              ["hardware.min_vram_gb ≤ hardware.max_vram_gb", "warn"],
            ].map(([rule, level], i) => (
              <div style={`display:grid;grid-template-columns:1fr 100px;padding:10px 14px;border-top:${i ? "1px solid var(--border)" : "0"};align-items:center`}>
                <span>{rule}</span>
                <Badge tone={level === "required" ? "error" : "warning"}>{level}</Badge>
              </div>
            ))}
          </div>
        </div>
        <div id="pr-flow" class="contribute-section">
          <h2 style="font-size:30px;margin:0 0 12px">PR flow</h2>
          <ol style="margin:0;padding-left:18px;font-size:16px;line-height:1.7;max-width:62ch">
            <li>Fork <code class="mono">flyingnobita/llml-catalog</code></li>
            <li>Add your TOML under <code class="mono">profiles/&lt;name&gt;.toml</code></li>
            <li>Run <code class="mono">python scripts/validate_profiles.py profiles/*.toml</code> locally</li>
            <li>Open a PR with one paragraph about your machine</li>
          </ol>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<script>
  var tocLinks = Array.from(document.querySelectorAll("[data-toc-link]"));

  function setActiveSection(id) {
    tocLinks.forEach(function(link) {
      var isActive = link.getAttribute("data-toc-link") === id;
      link.style.color = isActive ? "var(--ink)" : "var(--muted)";
      link.style.borderBottom = isActive ? "1px solid var(--ink)" : "none";
      if (isActive) {
        link.setAttribute("aria-current", "location");
      } else {
        link.removeAttribute("aria-current");
      }
    });

    document.querySelectorAll(".contribute-section").forEach(function(section) {
      section.classList.toggle("is-active", section.id === id);
    });
  }

  function activeIdFromHash() {
    var hashId = decodeURIComponent(window.location.hash.replace(/^#/, ""));
    if (hashId && document.getElementById(hashId)) return hashId;
    return tocLinks[0] ? tocLinks[0].getAttribute("data-toc-link") : "";
  }

  tocLinks.forEach(function(link) {
    link.addEventListener("click", function() {
      var id = link.getAttribute("data-toc-link");
      if (id) setActiveSection(id);
    });
  });
  window.addEventListener("hashchange", function() {
    setActiveSection(activeIdFromHash());
  });
  setActiveSection(activeIdFromHash());
</script>

<style is:global>
  .contribute-section {
    border-radius: var(--r-md);
    box-shadow: inset 3px 0 0 transparent;
    margin: -12px -16px;
    padding: 12px 16px;
    transition:
      background-color var(--d-short) var(--ease-move),
      box-shadow var(--d-short) var(--ease-move);
  }

  .contribute-section.is-active {
    background: color-mix(in oklch, var(--primary) 7%, transparent);
    box-shadow: inset 3px 0 0 var(--primary);
  }

  /* ---- contribute mobile (≤700px) ---- */
  @media (max-width: 700px) {
    /* Hero — stack grid, shrink heading */
    body > section:first-of-type > div:first-child {
      grid-template-columns: 1fr !important;
      gap: 32px !important;
    }
    body > section:first-of-type h1 {
      font-size: 32px !important;
    }
    body > section:first-of-type {
      padding: 40px 16px !important;
    }
    /* Hero code block — constrain width */
    body > section:first-of-type pre {
      max-height: 240px !important;
      font-size: 11px !important;
    }

    /* Content — stack sidebar above article */
    body > section:last-of-type > div:first-child {
      grid-template-columns: 1fr !important;
      gap: 32px !important;
    }
    body > section:last-of-type {
      padding: 40px 16px !important;
    }
    body > section:last-of-type aside ol {
      flex-direction: row !important;
      flex-wrap: wrap !important;
      gap: 12px !important;
    }
    body > section:last-of-type h2 {
      font-size: 24px !important;
    }

    /* Validation table — tighter on mobile */
    [style*="grid-template-columns:1fr 100px"] {
      grid-template-columns: 1fr 70px !important;
      font-size: 11px !important;
      padding: 8px 10px !important;
    }
  }

  /* ---- contribute tablet (701–1024px) ---- */
  @media (min-width: 701px) and (max-width: 1024px) {
    body > section:first-of-type > div:first-child {
      gap: 40px !important;
    }
    body > section:first-of-type h1 {
      font-size: 38px !important;
    }
    body > section:last-of-type > div:first-child {
      grid-template-columns: 180px 1fr !important;
      gap: 32px !important;
    }
  }
</style>

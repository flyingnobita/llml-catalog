---
// InstallBlock.astro — three-tab install/import/download block.
import { INSTALL_COMMANDS } from "../data/profiles";

export interface Props {
  profile: {
    importCmd: string;
    downloadUrl: string;
    backend: string;
    name: string;
  };
}

const { profile } = Astro.props;
const minVersion = "0.5.0";

const osTabs = [
  { id: "mac", label: "Mac" },
  { id: "linux", label: "Linux" },
  { id: "windows", label: "Windows" },
];
const defaultOS = "mac";
---

<div class="install-block" data-component="install-block">
  <!-- Version badge -->
  <div class="ib-badge">Requires llml &ge; {minVersion}</div>

  <!-- Tab bar -->
  <div class="ib-tabs" role="tablist">
    <button class="ib-tab active" data-tab="run" role="tab" aria-selected="true">Run</button>
    <button class="ib-tab" data-tab="install" role="tab" aria-selected="false">Install + run</button>
    <button class="ib-tab" data-tab="download" role="tab" aria-selected="false">Download</button>
  </div>

  <!-- Run tab -->
  <div class="ib-panel active" data-panel="run">
    <div class="ib-cmd">
      <span class="ib-cmd-text"><span class="ib-prompt">$</span> {profile.importCmd}</span>
      <button class="ib-copy" data-copy={profile.importCmd}>Copy</button>
    </div>
  </div>

  <!-- Install + run tab -->
  <div class="ib-panel" data-panel="install">
    <div class="ib-os-tabs" role="tablist">
      {osTabs.map((os) => (
        <button class={`ib-os-tab${os.id === defaultOS ? " active" : ""}`} data-os={os.id} role="tab" aria-selected={os.id === defaultOS ? "true" : "false"}>
          {os.label}
        </button>
      ))}
    </div>
    {osTabs.map((os) => {
      const installCmd = INSTALL_COMMANDS[os.id] || "";
      const fullCmd = `${installCmd}\n${profile.importCmd}`;
      return (
        <div class={`ib-os-panel${os.id === defaultOS ? " active" : ""}`} data-os-panel={os.id}>
          <div class="ib-cmd ib-cmd-multi">
            <div class="ib-cmd-text">
              <div><span class="ib-prompt">$</span> {installCmd}</div>
              <div><span class="ib-prompt">$</span> {profile.importCmd}</div>
            </div>
            <button class="ib-copy" data-copy={fullCmd}>Copy</button>
          </div>
        </div>
      );
    })}
  </div>

  <!-- Download tab -->
  <div class="ib-panel" data-panel="download">
    <div class="ib-download-row">
      <a href={profile.downloadUrl} download class="ib-download-btn">Download .toml</a>
      <button class="ib-preview-toggle" data-action="toggle-preview">Show TOML</button>
    </div>
    <pre class="ib-toml-preview" data-toml-preview hidden></pre>
  </div>
</div>

<style>
  .install-block {
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .ib-badge {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    padding: 8px 12px;
    background: var(--paper-2);
    border-bottom: 1px solid var(--border);
    letter-spacing: .04em;
  }

  /* Tab bar */
  .ib-tabs {
    display: flex;
    border-bottom: 1px solid var(--border);
    background: var(--paper-2);
  }
  .ib-tab {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    color: var(--muted);
    background: transparent;
    border: 0;
    padding: 10px 18px;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: color var(--d-short) var(--ease-enter), border-color var(--d-short) var(--ease-enter);
  }
  .ib-tab.active {
    color: var(--fg);
    border-bottom-color: var(--primary);
  }

  /* Panels */
  .ib-panel { display: none; }
  .ib-panel.active { display: block; }

  /* Command block */
  .ib-cmd {
    display: flex;
    background: var(--surface-inverse);
    color: var(--surface-inverse-fg);
    align-items: stretch;
    font-family: var(--font-mono);
    font-size: 13px;
  }
  .ib-cmd-text {
    padding: 14px 16px;
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .ib-cmd-multi .ib-cmd-text {
    display: flex;
    flex-direction: column;
    gap: 6px;
    white-space: nowrap;
  }
  .ib-prompt {
    color: var(--muted);
    user-select: none;
    margin-right: 8px;
  }
  .ib-copy {
    background: transparent;
    color: var(--surface-inverse-fg);
    border: 0;
    border-left: 1px solid var(--border);
    padding: 0 18px;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    min-width: 90px;
    transition: background var(--d-short) var(--ease-enter);
    white-space: nowrap;
  }
  .ib-copy.copied {
    background: var(--success);
    color: #0d2b1c;
    border-left: 0;
  }

  /* OS sub-tabs */
  .ib-os-tabs {
    display: flex;
    border-bottom: 1px solid var(--border);
    background: var(--paper-1);
    padding: 0 8px;
  }
  .ib-os-tab {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    background: transparent;
    border: 0;
    padding: 8px 14px;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: color var(--d-short) var(--ease-enter), border-color var(--d-short) var(--ease-enter);
  }
  .ib-os-tab.active {
    color: var(--fg);
    border-bottom-color: var(--primary);
  }
  .ib-os-panel { display: none; }
  .ib-os-panel.active { display: block; }

  /* Download tab */
  .ib-download-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
  }
  .ib-download-btn {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    color: var(--fg);
    background: var(--paper-2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 8px 16px;
    cursor: pointer;
    text-decoration: none;
    transition: background var(--d-short) var(--ease-enter);
  }
  .ib-download-btn:hover {
    background: var(--border);
  }
  .ib-preview-toggle {
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--muted);
    background: transparent;
    border: 0;
    cursor: pointer;
    padding: 4px 0;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .ib-toml-preview {
    margin: 0;
    padding: 14px 16px;
    background: var(--surface-inverse);
    color: var(--surface-inverse-fg);
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.55;
    overflow-x: auto;
    max-height: 360px;
    overflow-y: auto;
    border-top: 1px solid var(--border);
  }
</style>

<script>
  function initInstallBlock(root: HTMLElement) {
    // Tab switching (main tabs)
    const tabs = root.querySelectorAll<HTMLButtonElement>(".ib-tab");
    const panels = root.querySelectorAll<HTMLElement>(".ib-panel");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const name = tab.dataset.tab;
        if (!name) return;
        tabs.forEach((t) => {
          t.classList.remove("active");
          t.setAttribute("aria-selected", "false");
        });
        tab.classList.add("active");
        tab.setAttribute("aria-selected", "true");
        panels.forEach((p) => {
          p.classList.toggle("active", p.dataset.panel === name);
        });
      });
    });

    // OS sub-tabs
    const osTabs = root.querySelectorAll<HTMLButtonElement>(".ib-os-tab");
    const osPanels = root.querySelectorAll<HTMLElement>(".ib-os-panel");

    osTabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const os = tab.dataset.os;
        if (!os) return;
        osTabs.forEach((t) => {
          t.classList.remove("active");
          t.setAttribute("aria-selected", "false");
        });
        tab.classList.add("active");
        tab.setAttribute("aria-selected", "true");
        osPanels.forEach((p) => {
          p.classList.toggle("active", p.dataset.osPanel === os);
        });
      });
    });

    // Copy buttons
    root.querySelectorAll<HTMLButtonElement>(".ib-copy").forEach((btn) => {
      btn.addEventListener("click", () => {
        const text = btn.dataset.copy;
        if (!text) return;
        navigator.clipboard?.writeText(text);
        const original = btn.textContent;
        btn.textContent = "✓ Copied";
        btn.classList.add("copied");
        setTimeout(() => {
          btn.textContent = original;
          btn.classList.remove("copied");
        }, 1200);
      });
    });

    // TOML preview toggle
    const toggle = root.querySelector<HTMLButtonElement>("[data-action='toggle-preview']");
    const tomlPreview = root.querySelector<HTMLElement>("[data-toml-preview]");
    if (toggle && tomlPreview) {
      let loaded = false;
      toggle.addEventListener("click", async () => {
        const isOpen = !tomlPreview.hidden;
        if (isOpen) {
          tomlPreview.hidden = true;
          toggle.textContent = "Show TOML";
          return;
        }
        if (!loaded) {
          toggle.textContent = "Loading…";
          try {
            const downloadUrl = root.querySelector<HTMLAnchorElement>(".ib-download-btn")?.getAttribute("href");
            if (downloadUrl) {
              const resp = await fetch(downloadUrl);
              if (resp.ok) {
                tomlPreview.textContent = await resp.text();
              } else {
                tomlPreview.textContent = `# Failed to load TOML (${resp.status})`;
              }
            }
          } catch {
            tomlPreview.textContent = "# Failed to load TOML";
          }
          loaded = true;
        }
        tomlPreview.hidden = false;
        toggle.textContent = "Hide TOML";
      });
    }
  }

  // Initialize all InstallBlock instances on the page.
  document.querySelectorAll<HTMLElement>("[data-component='install-block']").forEach(initInstallBlock);
</script>

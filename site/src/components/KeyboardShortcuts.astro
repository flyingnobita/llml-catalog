---
export interface Props {
  browseMode?: boolean;
}
const { browseMode = false } = Astro.props;
---

<div id="shortcuts-overlay" style="display:none;position:fixed;inset:0;z-index:30">
  <div id="shortcuts-backdrop" style="position:absolute;inset:0;background:rgba(0,0,0,0.3)"></div>
  <div id="shortcuts-modal" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);max-width:480px;width:calc(100% - 48px);background:var(--paper);border:1px solid var(--border);border-radius:var(--r-lg);box-shadow:var(--shadow-float);padding:32px;max-height:85vh;overflow-y:auto">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px">
      <h2 style="font-family:var(--font-serif);font-size:var(--text-2xl);line-height:var(--leading-tight);font-weight:400;margin:0">Keyboard shortcuts</h2>
      <button id="shortcuts-close" style="font:inherit;background:transparent;border:0;cursor:pointer;font-size:20px;color:var(--muted);padding:4px 8px;line-height:1" aria-label="Close">&times;</button>
    </div>

    <div style="margin-bottom:20px">
      <span class="eyebrow" style="display:block;margin-bottom:12px">Navigation</span>
      <div style="display:flex;flex-direction:column;gap:10px">
        <div style="display:flex;align-items:center;gap:12px">
          <span style="display:flex;gap:4px">
            <kbd style="font-family:var(--font-mono);font-size:11px;padding:2px 6px;border:1px solid var(--border);border-bottom-width:2px;border-radius:4px;background:var(--paper);color:var(--ink)">g</kbd>
            <kbd style="font-family:var(--font-mono);font-size:11px;padding:2px 6px;border:1px solid var(--border);border-bottom-width:2px;border-radius:4px;background:var(--paper);color:var(--ink)">b</kbd>
          </span>
          <span style="font-size:14px;color:var(--muted)">Go to Browse</span>
        </div>
        <div style="display:flex;align-items:center;gap:12px">
          <span style="display:flex;gap:4px">
            <kbd style="font-family:var(--font-mono);font-size:11px;padding:2px 6px;border:1px solid var(--border);border-bottom-width:2px;border-radius:4px;background:var(--paper);color:var(--ink)">g</kbd>
            <kbd style="font-family:var(--font-mono);font-size:11px;padding:2px 6px;border:1px solid var(--border);border-bottom-width:2px;border-radius:4px;background:var(--paper);color:var(--ink)">h</kbd>
          </span>
          <span style="font-size:14px;color:var(--muted)">Go to Home</span>
        </div>
      </div>
    </div>

    {browseMode && (
      <div style="margin-bottom:20px">
        <span class="eyebrow" style="display:block;margin-bottom:12px">Browse</span>
        <div style="display:flex;flex-direction:column;gap:10px">
          <div style="display:flex;align-items:center;gap:12px">
            <span style="display:flex;gap:4px">
              <kbd style="font-family:var(--font-mono);font-size:11px;padding:2px 6px;border:1px solid var(--border);border-bottom-width:2px;border-radius:4px;background:var(--paper);color:var(--ink)">j</kbd>
              <span style="font-size:11px;color:var(--muted)">/</span>
              <kbd style="font-family:var(--font-mono);font-size:11px;padding:2px 6px;border:1px solid var(--border);border-bottom-width:2px;border-radius:4px;background:var(--paper);color:var(--ink)">k</kbd>
            </span>
            <span style="font-size:14px;color:var(--muted)">Next / Previous profile</span>
          </div>
          <div style="display:flex;align-items:center;gap:12px">
            <kbd style="font-family:var(--font-mono);font-size:11px;padding:2px 6px;border:1px solid var(--border);border-bottom-width:2px;border-radius:4px;background:var(--paper);color:var(--ink)">Enter</kbd>
            <span style="font-size:14px;color:var(--muted)">Open focused profile</span>
          </div>
          <div style="display:flex;align-items:center;gap:12px">
            <kbd style="font-family:var(--font-mono);font-size:11px;padding:2px 6px;border:1px solid var(--border);border-bottom-width:2px;border-radius:4px;background:var(--paper);color:var(--ink)">Space</kbd>
            <span style="font-size:14px;color:var(--muted)">Select / Deselect profile for compare</span>
          </div>
          <div style="display:flex;align-items:center;gap:12px">
            <kbd style="font-family:var(--font-mono);font-size:11px;padding:2px 6px;border:1px solid var(--border);border-bottom-width:2px;border-radius:4px;background:var(--paper);color:var(--ink)">c</kbd>
            <span style="font-size:14px;color:var(--muted)">Compare selected profiles</span>
          </div>
          <div style="display:flex;align-items:center;gap:12px">
            <kbd style="font-family:var(--font-mono);font-size:11px;padding:2px 6px;border:1px solid var(--border);border-bottom-width:2px;border-radius:4px;background:var(--paper);color:var(--ink)">/</kbd>
            <span style="font-size:14px;color:var(--muted)">Focus search</span>
          </div>
        </div>
      </div>
    )}

    <div>
      <span class="eyebrow" style="display:block;margin-bottom:12px">General</span>
      <div style="display:flex;flex-direction:column;gap:10px">
        <div style="display:flex;align-items:center;gap:12px">
          <kbd style="font-family:var(--font-mono);font-size:11px;padding:2px 6px;border:1px solid var(--border);border-bottom-width:2px;border-radius:4px;background:var(--paper);color:var(--ink)">?</kbd>
          <span style="font-size:14px;color:var(--muted)">Show keyboard shortcuts</span>
        </div>
        <div style="display:flex;align-items:center;gap:12px">
          <kbd style="font-family:var(--font-mono);font-size:11px;padding:2px 6px;border:1px solid var(--border);border-bottom-width:2px;border-radius:4px;background:var(--paper);color:var(--ink)">Esc</kbd>
          <span style="font-size:14px;color:var(--muted)">Close overlay</span>
        </div>
      </div>
    </div>
  </div>
</div>

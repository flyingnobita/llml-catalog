---
// Badge.astro — reusable badge atom.
export interface Props {
  tone?: "neutral" | "fill" | "success" | "warning" | "error" | "info";
  mono?: boolean;
  class?: string;
}
const { tone = "neutral", mono = true, class: className } = Astro.props;
const tones: Record<string, { bg: string; fg: string; bd: string }> = {
  neutral: { bg: "var(--paper)", fg: "var(--ink)", bd: "var(--border)" },
  fill: { bg: "var(--paper-2)", fg: "var(--ink)", bd: "var(--border)" },
  success: { bg: "color-mix(in oklch, var(--success) 15%, transparent)", fg: "var(--success)", bd: "color-mix(in oklch, var(--success) 40%, transparent)" },
  warning: { bg: "color-mix(in oklch, var(--warning) 15%, transparent)", fg: "var(--warning)", bd: "color-mix(in oklch, var(--warning) 40%, transparent)" },
  error:   { bg: "color-mix(in oklch, var(--error) 15%, transparent)",   fg: "var(--error)",   bd: "color-mix(in oklch, var(--error) 40%, transparent)" },
  info:    { bg: "color-mix(in oklch, var(--info) 15%, transparent)",    fg: "var(--info)",    bd: "color-mix(in oklch, var(--info) 40%, transparent)" },
};
const t = tones[tone];
const font = mono ? "var(--font-mono)" : "var(--font-sans)";
---

<span
  class={className}
  style={{
    fontFamily: font,
    fontSize: "12px",
    background: t.bg,
    color: t.fg,
    border: `1px solid ${t.bd}`,
    padding: "3px 9px",
    borderRadius: "4px",
    whiteSpace: "nowrap",
  }}
>
  <slot />
</span>

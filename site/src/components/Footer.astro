---
// Footer.astro — shared footer.
---

<footer style="padding:32px;border-top:1px solid var(--border)">
  <div style="max-width:1280px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;font-family:var(--font-mono);font-size:12px;color:var(--muted);flex-wrap:wrap;gap:12px">
    <span>LLM Launcher · MIT</span>
    <span class="shortcuts-hint" style="display:flex;align-items:center;gap:6px">
      Press
      <kbd style="font-family:var(--font-mono);font-size:11px;padding:2px 6px;border:1px solid var(--border);border-bottom-width:2px;border-radius:4px;background:var(--paper);color:var(--ink)">?</kbd>
      for keyboard shortcuts
    </span>
  </div>
</footer>

<style>
  .shortcuts-hint {
    display: none !important;
  }
  @media (min-width: 701px) {
    .shortcuts-hint {
      display: flex !important;
    }
  }
</style>

---
// Nav.astro — sticky top navigation bar.
import Button from "./Button.astro";

const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

function link(href: string, label: string) {
  const fullHref = base + href;
  const active = currentPath === fullHref || (href !== "/" && currentPath.startsWith(fullHref));
  const color = active ? "var(--ink)" : "var(--muted)";
  const border = active ? "1px solid var(--ink)" : "1px solid transparent";
  return { href: fullHref, label, color, border };
}
---

<header style="border-bottom:1px solid var(--border);background:var(--paper);position:sticky;top:0;z-index:10">
  <div style="max-width:1280px;margin:0 auto;padding:16px 32px;display:flex;align-items:center;gap:32px">
    <a href={`${base}/`} style="font:inherit;background:transparent;border:0;cursor:pointer;padding:0;display:flex;align-items:baseline;gap:10px;text-decoration:none">
      <span style="font-family:var(--font-serif);font-style:italic;font-size:28px;line-height:1;letter-spacing:-0.02em;color:var(--ink)">llml</span>
      <span style="font-family:var(--font-mono);font-size:11px;color:var(--muted);letter-spacing:.08em;text-transform:uppercase">profile catalog</span>
    </a>
    <nav style="display:flex;gap:24px;margin-left:12px">
      {["/browse", "/compare", "/how", "/contribute"].map((href) => {
        const l = link(href, href === "/browse" ? "Browse Profiles" : href === "/compare" ? "Compare" : href === "/how" ? "How It Works" : "Contribute");
        return (
          <a href={l.href} style={`font:inherit;font-family:var(--font-sans);font-size:14px;font-weight:500;background:transparent;border:0;padding:6px 2px;color:${l.color};border-bottom:${l.border};cursor:pointer;white-space:nowrap;text-decoration:none`}>
            {l.label}
          </a>
        );
      })}
    </nav>
    <div style="margin-left:auto;display:flex;gap:12px;align-items:center">
      <a href="https://github.com/flyingnobita/llml" style="font-family:var(--font-mono);font-size:12px;color:var(--muted);border-bottom:1px solid transparent;text-decoration:none">
        github.com/flyingnobita/llml ↗
      </a>

      <!-- Theme toggle (hidden when JS disabled) -->
      <button id="theme-toggle" class="no-js-hidden no-js-hidden--inline-flex" aria-label="Switch to dark mode"
        style="font:inherit;background:transparent;border:1px solid var(--border);border-radius:8px;padding:6px 12px;cursor:pointer;align-items:center;gap:6px;font-family:var(--font-sans);font-size:13px;color:var(--muted);min-height:44px;min-width:44px;justify-content:center;white-space:nowrap"
      >
        <!-- Sun icon (shown in light mode) -->
        <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
        <!-- Moon icon (shown in dark mode) -->
        <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;display:none"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        <span>Light</span>
      </button>

      <Button variant="secondary" href={`${base}/browse`}>Browse</Button>
    </div>
  </div>
</header>

<script>
  (function () {
    const html = document.documentElement;
    const toggle = document.getElementById("theme-toggle");
    if (!toggle) return;

    const iconSun = toggle.querySelector(".icon-sun") as HTMLElement;
    const iconMoon = toggle.querySelector(".icon-moon") as HTMLElement;
    const label = toggle.querySelector("span") as HTMLElement;

    function setUI(theme: string) {
      if (theme === "dark") {
        iconSun.style.display = "none";
        iconMoon.style.display = "";
        label.textContent = "Dark";
        toggle.setAttribute("aria-label", "Switch to light mode");
      } else {
        iconSun.style.display = "";
        iconMoon.style.display = "none";
        label.textContent = "Light";
        toggle.setAttribute("aria-label", "Switch to dark mode");
      }
    }

    // Initial UI
    setUI(html.getAttribute("data-theme") || "light");

    // Listen for OS preference changes
    const mq = window.matchMedia("(prefers-color-scheme: dark)");
    mq.addEventListener("change", (e) => {
      // Only follow OS preference if no explicit stored choice
      try {
        if (!localStorage.getItem("llml-theme")) {
          const theme = e.matches ? "dark" : "light";
          html.classList.add("theme-transition");
          html.setAttribute("data-theme", theme);
          setUI(theme);
        }
      } catch (_) { /* localStorage unavailable */ }
    });

    // Listen for cross-tab changes
    window.addEventListener("storage", (e) => {
      if (e.key === "llml-theme" && e.newValue) {
        const theme = e.newValue === "dark" ? "dark" : "light";
        html.classList.add("theme-transition");
        html.setAttribute("data-theme", theme);
        setUI(theme);
      }
    });

    toggle.addEventListener("click", () => {
      const current = html.getAttribute("data-theme");
      const next = current === "dark" ? "light" : "dark";
      html.classList.add("theme-transition");
      html.setAttribute("data-theme", next);
      setUI(next);
      try { localStorage.setItem("llml-theme", next); } catch (_) {}
    });
  })();
</script>

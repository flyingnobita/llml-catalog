---
// BaseLayout.astro — wraps every page with CSS tokens, fonts, Nav, and Footer.
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import KeyboardShortcuts from "../components/KeyboardShortcuts.astro";

export interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL;
const isBrowse = Astro.url.pathname === base + "browse" || Astro.url.pathname === base + "browse/";
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} · LLM Launcher</title>
  {description && <meta name="description" content={description} />}

  <!-- Blocking script: resolve theme before stylesheet to prevent flash of wrong theme -->
  <script is:inline>
    (function () {
      const stored = (function () {
        try { return localStorage.getItem("llml-theme"); } catch (_) { return null; }
      })();
      const osDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      const theme = stored === "dark" || stored === "light" ? stored : (osDark ? "dark" : "light");
      document.documentElement.setAttribute("data-theme", theme);
    })();
  </script>

  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  <link rel="stylesheet" href={`${import.meta.env.BASE_URL}styles/colors_and_type.css`} />
  <style is:global>
    body { margin: 0; }

    /* Transition for theme changes (only when user has no motion preference) */
    @media (prefers-reduced-motion: no-preference) {
      html.theme-transition,
      html.theme-transition *,
      html.theme-transition *::before,
      html.theme-transition *::after {
        transition: background-color 280ms var(--ease-move),
                    color 280ms var(--ease-move),
                    border-color 280ms var(--ease-move),
                    box-shadow 280ms var(--ease-move),
                    opacity 280ms var(--ease-move) !important;
        transition-delay: 0s !important;
      }
    }

    /* Hide toggle when JS is disabled —
       toggle sets a class on html to override this */
    .no-js-hidden { display: none; }
    html.js .no-js-hidden { display: initial; }
    html.js .no-js-hidden--flex { display: flex; }
    html.js .no-js-hidden--inline-flex { display: inline-flex; }
  </style>
</head>
<body data-page={isBrowse ? "browse" : "default"}>
  <script is:inline>
    // Mark JS as available (re-hide fallback content, show JS-dependent UI)
    document.documentElement.classList.add("js");
  </script>
  <Nav />
  <slot />
  <Footer />
  <KeyboardShortcuts browseMode={isBrowse} />
  <script define:vars={{ base }}>
    (function () {
      var overlay = document.getElementById("shortcuts-overlay");
      var backdrop = document.getElementById("shortcuts-backdrop");
      var closeBtn = document.getElementById("shortcuts-close");
      if (!overlay || !backdrop || !closeBtn) return;

      var chordPrefix = null;
      var chordTimer = null;

      function clearChord() {
        chordPrefix = null;
        if (chordTimer) { clearTimeout(chordTimer); chordTimer = null; }
      }

      function showOverlay() {
        overlay.style.display = "block";
        document.body.style.overflow = "hidden";
      }

      function hideOverlay() {
        overlay.style.display = "none";
        document.body.style.overflow = "";
        clearChord();
      }

      function toggleOverlay() {
        if (overlay.style.display === "block") {
          hideOverlay();
        } else {
          showOverlay();
        }
      }

      backdrop.addEventListener("click", hideOverlay);
      closeBtn.addEventListener("click", hideOverlay);

      document.addEventListener("keydown", function (e) {
        // When overlay is open, capture all keys — only Escape closes
        if (overlay.style.display === "block") {
          if (e.key === "Escape") {
            e.preventDefault();
            hideOverlay();
          }
          e.stopPropagation();
          return;
        }

        // Ignore when focus is in a form control
        var tag = e.target.tagName;
        if (tag === "INPUT" || tag === "SELECT" || tag === "TEXTAREA") return;

        // Handle chord prefix
        if (chordPrefix === "g") {
          clearChord();
          if (e.key === "b") {
            e.preventDefault();
            window.location.href = base + "browse";
            return;
          }
          if (e.key === "h") {
            e.preventDefault();
            window.location.href = base;
            return;
          }
          return;
        }

        if (e.key === "g") {
          e.preventDefault();
          chordPrefix = "g";
          chordTimer = setTimeout(clearChord, 800);
          return;
        }

        if (e.key === "?") {
          e.preventDefault();
          toggleOverlay();
          return;
        }
      });
    })();
  </script>
</body>
</html>
